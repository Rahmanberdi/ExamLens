{
  "version": 2,
  "builds": [
    {
      "src": "ExamLens/ExamLens/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "ExamLens/ExamLens/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "ExamLens/ExamLens/wsgi.py" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/favicon\\.svg", "dest": "frontend/dist/favicon.svg" },
    { "src": "/icons\\.svg", "dest": "frontend/dist/icons.svg" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
