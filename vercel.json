{
  "version": 2,
  "builds": [
    {
      "src": "ExamLens/ExamLens/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "ExamLens/ExamLens/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "ExamLens/ExamLens/wsgi.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
